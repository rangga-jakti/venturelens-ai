# VentureLens AI - Environment Configuration
# Copy this to .env and fill in your values

# Django Core
SECRET_KEY=django-insecure-change-this-to-a-long-random-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://venturelens_user:password@localhost:5432/venturelens_db

# AI / LLM Configuration
# Groq API (recommended - fast & free tier available)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (fallback)
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Primary LLM provider: "groq" or "openai"
LLM_PROVIDER=groq

# Cache (optional - defaults to LocMemCache)
# REDIS_URL=redis://localhost:6379/0

# Rate limiting
MAX_ANALYSES_PER_DAY=10
